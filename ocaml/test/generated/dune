(library
 (name generated)
 (libraries flatbuffers))

(rule
 (alias gen-sample)
 (deps (:schemas %{workspace_root}/flatbuffers/samples/monster.fbs
       %{workspace_root}/flatbuffers/benchmarks/cpp/flatbuffers/bench.fbs
       %{workspace_root}/flatbuffers/tests/monster_test.fbs
       %{workspace_root}/flatbuffers/tests/monster_extra.fbs
       %{workspace_root}/flatbuffers/tests/arrays_test.fbs
       %{workspace_root}/flatbuffers/tests/64bit/test_64bit.fbs)
  (:include (source_tree %{workspace_root}/flatbuffers/tests/include_test)))
 (targets monster.ml monster.mli
          bench.ml bench.mli
          monster_test.ml monster_test.mli
          monster_extra.ml monster_extra.mli
          arrays_test.ml arrays_test.mli
          test64_bit.ml test64_bit.mli)
 (mode promote)
 (action
   (progn
    (run flatc -I %{workspace_root}/flatbuffers/tests/include_test --ocaml %{schemas}))))
